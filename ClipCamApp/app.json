{
  "expo": {
    "name": "ClipCam",
    "slug": "clipcam",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0F19"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0B0F19"
      },
      "package": "com.william.clipcam"
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "ClipCam needs access to your camera to identify movies and screens playing in front of you."
        }
      ]
    ]
  }
}